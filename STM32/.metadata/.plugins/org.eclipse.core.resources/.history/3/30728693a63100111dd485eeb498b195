#ifndef INC_COMMS_H_
#define INC_COMMS_H_

#include <stdint.h>
#include <stdbool.h>

#define PACKET_DATA_SIZE 4

#define SYNC_1 0xF
#define SYNC_2 0xE

typedef struct _comms_packet_t {
	uint8_t sync1;
	uint8_t sync2;
	uint8_t cmd;
	uint8_t checksum;
	uint8_t data[PACKET_DATA_SIZE];
} comms_packet_t;

typedef enum _comms_packet_cmd {
	COMMS_TYPE_SET = 0,
	COMMS_TYPE_GET,
	COMMS_TYPE_ACK,
	COMMS_TYPE_ERR = 255,
} _comms_packet_cmd;

bool isPacketValid(comms_packet_t * _packet);
void packetFromBytes(comms_packet_t * _packet, uint8_t *buff);
void buildPacket(comms_packet_t * _packet, _comms_packet_cmd cmd, uint8_t *data);


#endif /* INC_COMMS_H_ */
